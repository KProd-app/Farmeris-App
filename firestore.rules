rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Apsauginės funkcijos patogumui
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /users/{userId} {
      // Visi prisijungę mato kitus (kad ūkininkas rastų darbuotojus)
      allow read: if isAuthenticated();
      // Redaguoti gali tik pats save
      allow write: if isOwner(userId);
    }

    match /laukai/{docId} {
      // Skaityti ir redaguoti gali tik ūkininkas
      allow read, update, delete: if isOwner(resource.data.ownerId);
      allow create: if isOwner(request.resource.data.ownerId);
    }

    match /sandelis/{docId} {
      allow read, update, delete: if isOwner(resource.data.ownerId);
      allow create: if isOwner(request.resource.data.ownerId);
    }

    match /finansai/{docId} {
      allow read, update, delete: if isOwner(resource.data.ownerId);
      allow create: if isOwner(request.resource.data.ownerId);
    }

    match /darbai/{docId} {
      // Ūkininkas gali daryti viską su savo sukurtais darbais
      // Darbuotojas gali tik skaityti ir atnaujinti, jeigu jis yra priskirtas prie to darbo
      allow read: if isOwner(resource.data.farmerId) || isOwner(resource.data.assignedWorkerId);
      allow create: if isOwner(request.resource.data.farmerId);
      allow update: if isOwner(resource.data.farmerId) || isOwner(resource.data.assignedWorkerId);
      allow delete: if isOwner(resource.data.farmerId);
    }
    
    // Numatytasis draudimas kitoms nesukonfigūruotoms kolekcijoms (Cybersecure-by-default)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
